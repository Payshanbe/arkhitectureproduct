
# Public canonical URL, for example http://localhost:3000 in development.
NEXT_PUBLIC_SITE_URL=

# Server-only PostgreSQL connection string. Never expose this with NEXT_PUBLIC_.
DATABASE_URI=

# Server-only random secret with at least 32 characters.
PAYLOAD_SECRET=

# Server-only token created when a Vercel Blob store is connected.
BLOB_READ_WRITE_TOKEN=
