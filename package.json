{
  "name": "arkhitectureweb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "payload": "payload",
    "seed": "payload run scripts/seed-flagship.ts",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "migrate:down": "payload migrate:down",
    "migrate:status": "payload migrate:status",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "media:migrate:vercel-blob": "payload run scripts/migrate-media-to-vercel-blob.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@payloadcms/db-postgres": "^3.85.2",
    "@payloadcms/next": "^3.85.2",
    "@payloadcms/storage-vercel-blob": "^3.85.2",
    "@vercel/blob": "^2.3.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "next": "^16.2.10",
    "payload": "^3.85.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "split-type": "^0.3.4",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "dompurify": "3.4.12",
    "next": {
      "postcss": "8.5.22"
    },
    "sharp": "$sharp"
  }
}
